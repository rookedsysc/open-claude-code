{
  "name": "opencode-claude-compat",
  "version": "0.1.0",
  "description": "OpenCode plugin package that adds Claude-style compatibility for plugins, commands, skills, agents, and MCP loading.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "docs",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compat": {
      "types": "./dist/compat.d.ts",
      "import": "./dist/compat.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "opencode",
    "plugin",
    "claude",
    "compatibility",
    "claude-code",
    "agent-skills",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rookedsysc/open-claude-code.git"
  },
  "bugs": {
    "url": "https://github.com/rookedsysc/open-claude-code/issues"
  },
  "homepage": "https://github.com/rookedsysc/open-claude-code#readme",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.2.24"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.24",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run typecheck && npm test",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  }
}
